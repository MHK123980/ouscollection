<div class="container-fluid px-4">
  <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h1 class="m-0">Dashboard</h1>
    <div class="d-flex align-items-center gap-2">
      <select id="reportMonthSelect" class="form-select form-select-sm bg-dark text-white border-dark" style="width: auto; cursor: pointer;">
        <option value="this_month">This Month</option>
        <option value="last_month">Last Month</option>
        <option value="both">Both Months</option>
      </select>
      <button onclick="exportReport()" class="btn btn-dark btn-sm text-nowrap">
        <i class="fas fa-file-pdf me-1"></i>Export Datasheet (PDF)
      </button>
    </div>
  </div>
  <script>
    function exportReport() {
      const selected = document.getElementById('reportMonthSelect').value;
      window.open('/admin/report?month=' + selected, '_blank');
    }
  </script>
  <%- include("../partials/errorMessage") %>
  <div class="row">
    <div class="col-xl-3 col-md-6">
      <div class="card bg-warning text-white mb-4">
        <div class="card-body">
          <div class="card-body-icon">
            <i class="fa-solid fa-clock"></i>
          </div>
          Pending Orders
        </div>
        <div class="card-footer d-flex align-items-center justify-content-between">
          <h3><%= orderStatusCount[0] %></h3>
          <div class="small text-white"><i class="fas fa-angle-right"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card bg-success text-white mb-4">
        <div class="card-body">
          <div class="card-body-icon">
            <i class="fa-solid fa-clipboard-check"></i>
          </div>
          Completed Orders
        </div>
        <div class="card-footer d-flex align-items-center justify-content-between">
          <h3><%= orderStatusCount[1] %></h3>
          <div class="small text-white"><i class="fas fa-angle-right"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card bg-danger text-white mb-4">
        <div class="card-body">
          <div class="card-body-icon">
            <i class="fa-solid fa-chart-simple"></i>
          </div>
          Total Sale
        </div>
        <div class="card-footer d-flex align-items-center justify-content-between">
          <h3>PKR <%= orderStatusCount[2] %></h3>
          <div class="small text-white"><i class="fas fa-angle-right"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card text-white mb-4" style="background-color: #6c757d;">
        <div class="card-body">
          <div class="card-body-icon">
            <i class="fa-solid fa-ban"></i>
          </div>
          Cancelled Orders
        </div>
        <div class="card-footer d-flex align-items-center justify-content-between">
          <h3><%= orderStatusCount[3] || 0 %></h3>
          <div class="small text-white"><i class="fas fa-angle-right"></i></div>
        </div>
      </div>
    </div>
  </div>
  <div class="row">
    <div class="col-xl-6">
      <div class="card mb-4">
        <div class="card-header">
          <i class="fas fa-chart-area me-1"></i>
          Sales
        </div>
        <div class="card-body"><canvas id="myAreaChart" width="100%" height="40"></canvas></div>
      </div>
    </div>
  </div>
</div>

<script src="/assets/diagram/graph.js"></script>
