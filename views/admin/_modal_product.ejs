<div class="modal fade" id="addProduct" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">Add Product</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/admin/addProduct" method="post" enctype="multipart/form-data" onsubmit="return handleAddSubmit(this)">
          <div>
            <label class="form-label">Name</label>
            <input type="text" value="" name="name" required class="form-control">
          </div>
          <div>
            <label class="form-label">Category <span class="text-muted">(Optional)</span></label>
            <select name="category" class="form-select category-select">
              <option value="">Select category...</option>
              <% const mensCats = allCategories.filter(c => c.division === 'Mens'); %>
              <% const womensCats = allCategories.filter(c => c.division === 'Womens'); %>
              <% if(mensCats.length > 0) { %>
                <optgroup label="Men's">
                  <% mensCats.forEach(cat => { %>
                  <option value="<%=cat._id %>"><%= cat.categoryName %></option>
                  <% }); %>
                </optgroup>
              <% } %>
              <% if(womensCats.length > 0) { %>
                <optgroup label="Women's">
                  <% womensCats.forEach(cat => { %>
                  <option value="<%=cat._id %>"><%= cat.categoryName %></option>
                  <% }); %>
                </optgroup>
              <% } %>
            </select>
          </div>
          <div>
            <label class="form-label">Stock</label>
            <input type="number" name="quantity" min="1" value="" required class="form-control">
          </div>
          <div>
            <label class="form-label">Price</label>
            <input type="number" name="price" min="1" value="" required class="form-control">
          </div>
          <div>
            <label class="form-label">Delivery Charges (Rs)</label>
            <input type="number" name="deliveryCharges" min="0" step="0.01" value="0" required class="form-control">
          </div>
          <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="increaseDeliveryChargesWithQuantity" id="increaseDeliveryChargesWithQuantity">
            <label class="form-check-label" for="increaseDeliveryChargesWithQuantity">Increase delivery charges with quantity</label>
          </div>
          <div>
            <label class="form-label">Discount <span class="text-muted">(in percentage)</span></label>
            <input type="number" name="discount" min="0" max="100" step="0.01" value="" class="form-control" placeholder="Optional">
          </div>

          <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" name="isFeatured" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">Is Featured ?</label>
          </div>
          <div><label class="form-label">Description</label></div>
          <div><textarea name="description" rows="5" placeholder="Add description" class="form-control" required></textarea></div>
          <div>
            <label class="form-label">Upload Product Image</label>
            <input type="file" multiple name="productImages" required class="form-control" onchange="previewProductImage(event)" id="productImagesInput">
            <div class="mt-2" id="previewProductImages">
              <!-- preview images while uploading images -->
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-dark" id="addSubmitBtn">Add Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function handleAddSubmit(form) {
    const btn = form.querySelector('#addSubmitBtn');
    btn.disabled = true;
    // Show beautiful loader overlay
    const overlay = document.getElementById('productLoaderOverlay');
    if (overlay) overlay.style.display = 'flex';
    // Hide modal to focus on loader
    $('#addProduct').modal('hide');
    return true; // continue submission
  }
  // Remove cache file of modal when closing
  $("#addProduct").on("hidden.bs.modal", function() {
    $(this).find('form').trigger('reset');
    productDataTransfer = new DataTransfer();
    document.getElementById("productImagesInput").files = productDataTransfer.files;
    $("#previewProductImages").html("")
    // Destroy Select2 when modal closes
    $(this).find('.category-select').select2('destroy');
  });

  // Advanced Image Upload Logic
  let productDataTransfer = new DataTransfer();

  async function previewProductImage(event) {
    const input = event.target;
    const btn = document.getElementById('addSubmitBtn');
    if(btn) btn.disabled = true;

    // Limit to 40 images to prevent Vercel Payload Too Large error
    let filesToProcess = Array.from(input.files);
    if (filesToProcess.length > 40) {
      alert("Maximum 40 images allowed per product. Only the first 40 will be uploaded.");
      filesToProcess = filesToProcess.slice(0, 40);
    }

    const options = {
      maxSizeMB: 0.08, // 80KB max to ensure 40 images fit within 4.5MB Vercel limit
      maxWidthOrHeight: 800,
      useWebWorker: true
    };
    
    for (let file of filesToProcess) {
      try {
        const compressedFile = await imageCompression(file, options);
        const newFile = new File([compressedFile], file.name, { type: file.type });
        productDataTransfer.items.add(newFile);
      } catch (err) {
        console.error("Image compression error:", err);
        productDataTransfer.items.add(file); // fallback
      }
    }
    input.files = productDataTransfer.files;
    renderProductPreview();
    if(btn) btn.disabled = false;
  }

  function renderProductPreview() {
    const container = document.getElementById("previewProductImages");
    container.innerHTML = "";
    
    if (productDataTransfer.files.length > 0) {
      container.innerHTML = `<div class="mb-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAllProductImages()">Delete All Images</button></div>`;
    }

    Array.from(productDataTransfer.files).forEach((file, index) => {
      let src = URL.createObjectURL(file);
      container.innerHTML += `
        <div class="d-inline-block position-relative m-1 border rounded p-1">
          <img src='${src}' alt='' width='70' height='70' class='rounded' style='object-fit:cover;'>
          <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" style="width:20px; height:20px; line-height:1; transform: translate(50%, -50%);" onclick="deleteProductImage(${index})">&times;</button>
        </div>
      `;
    });
  }

  function deleteProductImage(index) {
    const dt = new DataTransfer();
    Array.from(productDataTransfer.files).forEach((file, i) => {
      if (i !== index) dt.items.add(file);
    });
    productDataTransfer = dt;
    document.getElementById("productImagesInput").files = productDataTransfer.files;
    renderProductPreview();
  }

  function deleteAllProductImages() {
    productDataTransfer = new DataTransfer();
    document.getElementById("productImagesInput").files = productDataTransfer.files;
    renderProductPreview();
  }

  // Initialize Select2 for category dropdown
  $(document).ready(function() {
    // Initialize Select2 on page load
    $('#addProduct .category-select').select2({
      placeholder: "Search and select category...",
      allowClear: true,
      theme: "bootstrap-5",
      width: '100%',
      dropdownParent: $('#addProduct')
    });
  });

  // Re-initialize Select2 when modal is shown
  $('#addProduct').on('show.bs.modal', function () {
    $(this).find('.category-select').select2({
      placeholder: "Search and select category...",
      allowClear: true,
      theme: "bootstrap-5",
      width: '100%',
      dropdownParent: $('#addProduct')
    });
  });
</script>