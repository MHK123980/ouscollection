<div class="container-fluid px-4">
  <h1 class="mt-4">Order Management</h1>
  <%- include("../partials/errorMessage") %>
  <div class="card mb-4">
    <div class="card-header">
      <i class="fas fa-table me-1"></i>
      All Orders
      <button class="btn btn-dark btn-sm float-end" onclick="exportCsv()">Export <i class="fa-solid fa-download"></i></button>
      <a href="/admin/addOrder" class="btn btn-dark btn-sm float-end me-2">Add Order <i class="fa-solid fa-plus"></i></a>
    </div>
    <div class="card-body">
      <table id="datatablesSimple">
        <thead>
          <tr>
            <th>Order #</th>
            <th>Customer</th>
            <th>Address</th>
            <th>Products</th>
            <th>Total (PKR)</th>
            <th>Order Date</th>
            <th>Payment</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tfoot>
          <tr>
            <th>Order #</th>
            <th>Customer</th>
            <th>Address</th>
            <th>Products</th>
            <th>Total (PKR)</th>
            <th>Order Date</th>
            <th>Payment</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </tfoot>
        <tbody>
          <% allOrders.forEach(order=>{ %>
          <tr id="order-<%= order.id %>">
            <td><button onclick="viewOrderDetails('<%= order.id %>')" class="btn btn-link p-0 link-dark fw-bold"><%= order.orderIdStr || order.id %></button></td>
            <td>
              <%= order.deliveryAddress.firstName %> <%= order.deliveryAddress.lastName || '' %><br>
              <small class="text-muted"><%= order.deliveryAddress.phone || '' %></small>
            </td>
            <td>
              <%=order.deliveryAddress.address || '' %>,
              <%=order.deliveryAddress.city || '' %><% if(order.deliveryAddress.province) { %>,
              <%=order.deliveryAddress.province %><% } %><% if(order.deliveryAddress.state) { %>,
              <%=order.deliveryAddress.state %><% } %>
            </td>
            <td>
              <% order.products.forEach(product=>{ %>
              <%= product.name %> x<%= product.quantity %>,
              <% }) %>
            </td>
            <td>PKR <%=order.total.toFixed(2) %></td>
            <td><%=order.createdAt.toDateString() %></td>
            <% if(order.paymentType == "cod" ){%>
            <td><span class="badge" style="background-color:rgb(177, 39, 85) ;">COD</span></td>
            <%}else{%>
            <td><span class="badge bg-success">Online ✅</span></td>
            <% } %>
            <td><span class="badge order-status" id="status-<%= order.id%>"><%=order.status %></span></td>
            <td id="action-<%= order.id %>" class="text-center">
              <div class="d-flex flex-column gap-1 align-items-center">
                <button onclick="viewOrderDetails('<%= order.id %>')" class="btn btn-sm btn-outline-primary w-100"><i class="fa-solid fa-eye"></i> View</button>
                <button onclick="printSlip('<%= order.id %>')" class="btn btn-sm btn-outline-secondary w-100"><i class="fa-solid fa-print"></i> Print</button>
                <button id="delete-btn-<%= order.id %>" class="btn btn-sm btn-outline-danger w-100" onclick="deleteOrder('<%=order.id%>')" style="display: <%= (order.status === 'Delivered' || order.status === 'Cancelled') ? 'block' : 'none' %>;"><i class="fa-solid fa-trash"></i> Delete</button>
                
                <select class="form-select form-select-sm mt-1" onchange="changeOrderStatus(this, '<%= order.id %>', '<%= order.status %>')" <%= order.status === 'Delivered' || order.status === 'Cancelled' ? 'disabled' : '' %>>
                  <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %> disabled>Pending</option>
                  <option value="Packed" <%= order.status === 'Packed' ? 'selected' : '' %>>Packed</option>
                  <option value="Shipped" <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                  <option value="Out for delivery" <%= order.status === 'Out for delivery' ? 'selected' : '' %>>Out for delivery</option>
                  <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                  <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Order Details Modal -->
  <div class="modal fade" id="orderDetailsModal" tabindex="-1" aria-labelledby="orderDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="orderDetailsModalLabel">Order Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="orderDetailsContent">
          <!-- Order details will be loaded here -->
        </div>
      </div>
    </div>
  </div>

  <script src="/js/order-management.js"></script>

  <script>
    let date = new Date().toLocaleDateString('en-US', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    })

    function exportCsv() {
      myTable.export({
        type: "csv",
        skipColumn:[8],
        filename: "order_report" + " " + date
      });
    }
  </script>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    if (typeof io !== 'undefined') {
      const socket = io();
      socket.on('new_order', (order) => {
        console.log('New order received:', order);
        toastr.info('New order received from ' + (order.deliveryAddress.firstName || 'Customer') + '!');
        
        const tbody = document.querySelector("#datatablesSimple tbody");
        if (tbody) {
          const tr = document.createElement("tr");
          tr.id = "order-" + order._id;
          
          let productsHTML = order.products.map(p => `<span class="badge bg-secondary">${p.name} x${p.quantity}</span>`).join(' ');
          let emailHTML = order.userId ? order.userId.email : (order.deliveryAddress.email || 'Guest');
          let orderIdHTML = order.orderIdStr || order._id;
          
          tr.innerHTML = `
            <td><button onclick="viewOrderDetails('${order._id}')" class="btn btn-link p-0 link-dark fw-bold">${orderIdHTML}</button></td>
            <td>${emailHTML}</td>
            <td>${order.deliveryAddress.firstName}</td>
            <td>${productsHTML}</td>
            <td>Rs ${order.total.toFixed(2)}</td>
            <td>${order.paymentType}</td>
            <td><span class="badge order-status bg-warning" id="status-${order._id}">${order.status}</span></td>
            <td id="action-${order._id}" class="text-center">
                <div class="d-flex flex-column gap-1 align-items-center">
                  <button onclick="viewOrderDetails('${order._id}')" class="btn btn-sm btn-outline-primary w-100"><i class="fa-solid fa-eye"></i> View</button>
                  <button onclick="printSlip('${order._id}')" class="btn btn-sm btn-outline-secondary w-100"><i class="fa-solid fa-print"></i> Print</button>
                  <button id="delete-btn-${order._id}" class="btn btn-sm btn-outline-danger w-100" onclick="deleteOrder('${order._id}')" style="display: none;"><i class="fa-solid fa-trash"></i> Delete</button>
                  
                  <select class="form-select form-select-sm mt-1" onchange="changeOrderStatus(this, '${order._id}', '${order.status}')">
                    <option value="Pending" selected disabled>Pending</option>
                    <option value="Packed" >Packed</option>
                    <option value="Shipped" >Shipped</option>
                    <option value="Out for delivery" >Out for delivery</option>
                    <option value="Delivered" >Delivered</option>
                    <option value="Cancelled" >Cancelled</option>
                  </select>
                </div>
            </td>
          `;
          
          if (tbody.firstChild) {
              tbody.insertBefore(tr, tbody.firstChild);
          } else {
              tbody.appendChild(tr);
          }
        }
      });
    }
  </script>
</div>