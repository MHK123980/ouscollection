<!-- Add Set Product Modal -->
<div class="modal fade" id="addSetProduct" tabindex="-1" aria-labelledby="addSetProductLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title" id="addSetProductLabel"><i class="fa-solid fa-boxes-stacked me-2"></i>Add Sets Product (Wholesale)</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-info small">
          <i class="fas fa-info-circle me-1"></i>
          Set products are wholesale items sold in sets. Enter the <strong>price per piece</strong> and the <strong>number of pieces per set</strong>. The total set price will be calculated automatically.
        </div>
        <form action="/admin/addProduct" method="post" enctype="multipart/form-data" onsubmit="return handleSetSubmit(event, this)">
          <!-- Hidden fields to mark as set -->
          <input type="hidden" name="isWholesaleSet" value="on">
          
          <div class="mb-3">
            <label class="form-label fw-bold">Product Name <span class="text-danger">*</span></label>
            <input type="text" name="name" required class="form-control" placeholder="e.g., Premium Cotton Kurta Set">
          </div>
          
          <div class="mb-3">
            <label class="form-label fw-bold">Category</label>
            <select name="category" class="form-select category-select-set">
              <option value="">Select category...</option>
              <% const mensCatsSet = allCategories.filter(c => c.division === 'Mens'); %>
              <% const womensCatsSet = allCategories.filter(c => c.division === 'Womens'); %>
              <% if(mensCatsSet.length > 0) { %>
                <optgroup label="Men's">
                  <% mensCatsSet.forEach(cat => { %>
                  <option value="<%=cat._id %>"><%= cat.categoryName %></option>
                  <% }); %>
                </optgroup>
              <% } %>
              <% if(womensCatsSet.length > 0) { %>
                <optgroup label="Women's">
                  <% womensCatsSet.forEach(cat => { %>
                  <option value="<%=cat._id %>"><%= cat.categoryName %></option>
                  <% }); %>
                </optgroup>
              <% } %>
            </select>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label fw-bold">Number of Sets in Stock <span class="text-danger">*</span></label>
              <input type="number" name="quantity" min="1" required class="form-control" placeholder="e.g., 20" id="setStockInput">
              <small class="text-muted">How many complete sets are available</small>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Pieces per Set <span class="text-danger">*</span></label>
              <input type="number" name="piecesPerSet" min="1" value="1" required class="form-control" placeholder="e.g., 5" id="piecesPerSetInput" oninput="calcSetTotal()">
              <small class="text-muted">e.g., 5 pieces, 7 pieces, 10 pieces</small>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label fw-bold">Price per Piece (PKR) <span class="text-danger">*</span></label>
              <input type="number" name="price" min="1" required class="form-control" placeholder="e.g., 2250" id="pricePerPieceInput" oninput="calcSetTotal()">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Total Set Price</label>
              <div class="form-control bg-light" id="totalSetPrice" style="font-size: 1.1rem; font-weight: bold; color: #198754;">PKR 0.00</div>
              <small class="text-muted">Auto-calculated: Price × Pieces</small>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Delivery Charges (PKR)</label>
              <input type="number" name="deliveryCharges" min="0" step="0.01" value="0" class="form-control">
            </div>
            <div class="col-md-6">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" name="increaseDeliveryChargesWithQuantity" id="setDeliveryIncrease">
                <label class="form-check-label" for="setDeliveryIncrease">Increase delivery with quantity</label>
              </div>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Discount <span class="text-muted">(percentage)</span></label>
            <input type="number" name="discount" min="0" max="100" step="0.01" class="form-control" placeholder="Optional">
          </div>

          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" name="isFeatured" id="setFeaturedCheck">
            <label class="form-check-label" for="setFeaturedCheck">Is Featured?</label>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Description <span class="text-danger">*</span></label>
            <textarea name="description" rows="4" class="form-control" required placeholder="Describe the set product, fabric, colors, sizes included etc."></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Upload Product Images <span class="text-danger">*</span></label>
            <input type="file" multiple name="productImages" required class="form-control" onchange="previewSetImage(event)" id="setProductImagesInput">
            <div class="mt-2" id="previewSetImages"></div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-dark" id="addSetSubmitBtn"><i class="fa-solid fa-boxes-stacked me-1"></i>Add Sets Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function calcSetTotal() {
    const price = parseFloat(document.getElementById('pricePerPieceInput').value) || 0;
    const pieces = parseInt(document.getElementById('piecesPerSetInput').value) || 0;
    const total = price * pieces;
    document.getElementById('totalSetPrice').innerHTML = 'PKR ' + total.toFixed(2);
  }

  async function handleSetSubmit(event, form) {
    event.preventDefault();
    const btn = form.querySelector('#addSetSubmitBtn');
    if(btn) btn.disabled = true;
    
    const overlay = document.getElementById('productLoaderOverlay');
    const loaderText = document.getElementById('loaderText');
    const progressBar = document.getElementById('uploadProgressBar');
    const progressFill = document.getElementById('uploadProgressFill');
    if (overlay) overlay.style.display = 'flex';
    if (progressBar) progressBar.style.display = 'block';
    
    try {
        let files = setProductDataTransfer.files;
        if (files.length > 0) {
            for (let i = 0; i < files.length; i++) {
                let pct = Math.round(((i + 1) / files.length) * 100);
                if(loaderText) loaderText.innerText = `Uploading HD Image ${i + 1} of ${files.length}...`;
                if(progressFill) progressFill.style.width = pct + '%';
                
                let fd = new FormData();
                fd.append('image', files[i]);
                let res = await fetch('/admin/uploadSingleImage', { method: 'POST', body: fd });
                let data = await res.json();
                if (data.success) {
                    let hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'uploadedImages';
                    hiddenInput.value = data.url;
                    form.appendChild(hiddenInput);
                } else {
                    throw new Error(data.message || "Upload failed");
                }
            }
        }
        
        // CRITICAL: Remove the file input name so files are NOT sent with form.submit()
        const fileInput = document.getElementById("setProductImagesInput");
        if (fileInput) fileInput.removeAttribute('name');
        
        $('#addSetProduct').modal('hide');
        if(loaderText) loaderText.innerText = "Saving product details...";
        form.submit();
    } catch (e) {
        alert("Upload error: " + e.message);
        if(overlay) overlay.style.display = 'none';
        if(progressBar) progressBar.style.display = 'none';
        if(btn) btn.disabled = false;
    }
    return false;
  }

  // Advanced Image Upload Logic
  let setProductDataTransfer = new DataTransfer();

  async function previewSetImage(event) {
    const input = event.target;
    const btn = document.getElementById('addSetSubmitBtn');
    if(btn) btn.disabled = true;

    let filesToProcess = [];
    try {
      for (let file of input.files) {
        if (file.name.match(/\.zip$/i) || file.type === 'application/zip' || file.type === 'application/x-zip-compressed') {
          const zip = await JSZip.loadAsync(file);
          for (const [filename, zipEntry] of Object.entries(zip.files)) {
            if (!zipEntry.dir && filename.match(/\.(jpg|jpeg|png|webp|gif)$/i)) {
               const blob = await zipEntry.async("blob");
               filesToProcess.push(new File([blob], filename, { type: blob.type }));
            }
          }
        } else if (file.name.match(/\.pdf$/i) || file.type === 'application/pdf') {
          const arrayBuffer = await file.arrayBuffer();
          const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
          for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const viewport = page.getViewport({ scale: 1.5 });
            const canvas = document.createElement("canvas");
            const ctx = canvas.getContext("2d");
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            await page.render({ canvasContext: ctx, viewport: viewport }).promise;
            const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/jpeg", 0.9));
            filesToProcess.push(new File([blob], file.name.replace('.pdf','') + `-page-${i}.jpg`, { type: "image/jpeg" }));
          }
        } else if (file.type.startsWith("image/")) {
          filesToProcess.push(file);
        }
      }
    } catch (e) {
      console.error(e);
      alert("Error processing files: " + e.message);
    }

    if (filesToProcess.length > 60) {
      alert("cant upload images due to limit cross of images");
      input.value = "";
      if(btn) btn.disabled = false;
      return;
    }

    const options = {
      maxSizeMB: 0.7,
      maxWidthOrHeight: 1920,
      useWebWorker: true,
      initialQuality: 0.85
    };
    
    for (let file of filesToProcess) {
      try {
        const compressedFile = await imageCompression(file, options);
        const newFile = new File([compressedFile], file.name, { type: file.type });
        setProductDataTransfer.items.add(newFile);
      } catch (err) {
        console.error("Image compression error:", err);
        setProductDataTransfer.items.add(file); // fallback
      }
    }
    input.files = setProductDataTransfer.files;
    renderSetProductPreview();
    if(btn) btn.disabled = false;
  }

  function renderSetProductPreview() {
    const container = document.getElementById("previewSetImages");
    container.innerHTML = "";
    
    if (setProductDataTransfer.files.length > 0) {
      container.innerHTML = `<div class="mb-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAllSetProductImages()">Delete All Images</button></div>`;
    }

    Array.from(setProductDataTransfer.files).forEach((file, index) => {
      let src = URL.createObjectURL(file);
      container.innerHTML += `
        <div class="d-inline-block position-relative m-1 border rounded p-1">
          <img src='${src}' alt='' width='70' height='70' class='rounded' style='object-fit:cover;'>
          <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" style="width:20px; height:20px; line-height:1; transform: translate(50%, -50%);" onclick="deleteSetProductImage(${index})">&times;</button>
        </div>
      `;
    });
  }

  function deleteSetProductImage(index) {
    const dt = new DataTransfer();
    Array.from(setProductDataTransfer.files).forEach((file, i) => {
      if (i !== index) dt.items.add(file);
    });
    setProductDataTransfer = dt;
    document.getElementById("setProductImagesInput").files = setProductDataTransfer.files;
    renderSetProductPreview();
  }

  function deleteAllSetProductImages() {
    setProductDataTransfer = new DataTransfer();
    document.getElementById("setProductImagesInput").files = setProductDataTransfer.files;
    renderSetProductPreview();
  }

  // Initialize Select2 for set product modal
  $('#addSetProduct').on('show.bs.modal', function () {
    $(this).find('.category-select-set').select2({
      placeholder: "Search and select category...",
      allowClear: true,
      theme: "bootstrap-5",
      width: '100%',
      dropdownParent: $('#addSetProduct')
    });
  });

  $('#addSetProduct').on('hidden.bs.modal', function() {
    $(this).find('form').trigger('reset');
    setProductDataTransfer = new DataTransfer();
    document.getElementById("setProductImagesInput").files = setProductDataTransfer.files;
    // Restore the name attribute in case it was removed
    document.getElementById("setProductImagesInput").setAttribute('name', 'productImages');
    document.getElementById('previewSetImages').innerHTML = '';
    document.getElementById('totalSetPrice').innerHTML = 'PKR 0.00';
    $(this).find('.category-select-set').select2('destroy');
  });
</script>
