<div class="container-fluid px-4">
  <h1 class="mt-4">Product Management</h1>
  <%- include("../partials/errorMessage") %>
    <div class="card mb-4">
      <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Products
        <%- include("_modal_product") %>
        <%- include("_modal_set_product") %>
          <div class=" float-end">
            <button class="btn btn-dark btn-sm" onclick="exportCsv()">Export <i
                class="fa-solid fa-download"></i></button>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addSetProduct"><i class="fa-solid fa-boxes-stacked"></i> Add Sets Product</button>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addProduct">New Product <i
                class="fa-solid fa-circle-plus"></i></button>
          </div>
      </div>
      <div class="card-body">
        <table id="datatablesSimple">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Price</th>
              <th>Discount %</th>
              <th>Offer Price</th>
              <th>Is Featured</th>
              <th>Action</th>
            </tr>
          </thead>
          <tfoot>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Price</th>
              <th>Discount %</th>
              <th>Offer Price</th>
              <th>Is Featured</th>
              <th>Action</th>
            </tr>
          </tfoot>
          <tbody>
            <% allProducts.forEach(product=>{ %>
              <tr>
                <td><img
                    src="<%= product.productImagePath[0].startsWith('http') ? product.productImagePath[0] : '/files/' + product.productImagePath[0] %>"
                    alt="<%= product.name %>" width="60" class="img-fluid img-thumbnail"></td>
                <td>
                  <%= product.name %>
                  <% if(product.isWholesaleSet) { %>
                    <br><span class="badge text-white mt-1" style="background-color:#7fad39; font-size:0.7rem; letter-spacing:1px;"><i class="fa-solid fa-boxes-stacked me-1"></i>SET</span>
                  <% } %>
                </td>
                <td>
                  <%= product.category ? product.category.categoryName : '-' %>
                </td>
                <td>
                  <%= product.quantity %>
                </td>
                <td>
                  <%= product.price %>
                </td>
                <td>
                  <%= product.discount %>
                </td>
                <td>
                  <%= product.offerPrice %>
                </td>
                <% if(product.isFeatured){%>
                  <td><span class="badge bg-success">Featured</span></td>
                  <%}else{%>
                    <td></td>
                    <% } %>
                      <td>
                        <form action="/admin/deleteProduct/<%= product.id%>?_method=DELETE" method="post">
                          <div>
                            <button class="btn btn-sm btn-outline-dark" data-bs-toggle="modal"
                              data-bs-target="#edit-<%= product.id %>" type="button"><i
                                class="fa-solid fa-pen-to-square"></i></button>
                            <a class="btn btn-sm btn-outline-danger" href="#deleteModal<%= product.id %>"
                              data-bs-toggle="modal"><i class="fa-solid fa-trash-can"></i></a>
                          </div>
                          <!-- delete modal start -->
                          <div class="modal modal-alert" tabindex="-1" role="dialog" id="deleteModal<%= product.id %>">
                            <div class="modal-dialog modal-dialog-centered" role="document">
                              <div class="modal-content rounded-3 shadow">
                                <div class="modal-body p-4 text-center">
                                  <h5 class="mb-2">Waring! Are you sure</h5>
                                  <p class="mb-0">This change cant be undone.</p>
                                </div>
                                <div class="modal-footer flex-nowrap p-0">
                                  <button type="submit"
                                    class="btn btn-lg btn-link fs-6 text-decoration-none col-6 m-0 rounded-0 border-end"><strong>Yes</strong></button>
                                  <button type="button"
                                    class="btn btn-lg btn-link fs-6 text-decoration-none col-6 m-0 rounded-0"
                                    data-bs-dismiss="modal">No</button>
                                </div>
                              </div>
                            </div>
                          </div>

                          <!-- delete modal end -->

                        </form>
                      </td>
              </tr>
              <!-- modal body  -->
              <div class="modal fade" id="edit-<%= product.id %>" tabindex="-1" aria-labelledby="exampleModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title" id="exampleModalLabel">Edit Product</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      <form action="/admin/editProduct/<%= product.id %>?_method=PUT" method="post"
                        enctype="multipart/form-data" onsubmit="return handleEditSubmit(event, this, '<%= product.id %>')">
                        <div>
                          <label class="form-label">name</label>
                          <input type="text" value="<%=product.name %>" name="name" required class="form-control">
                        </div>
                        <div>
                          <label class="form-label">Category <span class="text-muted">(Optional)</span></label>
                          <select name="category" class="form-select category-select">
                            <option value="">Select category...</option>
                            <% const mensCats=allCategories.filter(c=> c.division === 'Mens'); %>
                              <% const womensCats=allCategories.filter(c=> c.division === 'Womens'); %>
                                <% if(mensCats.length> 0) { %>
                                  <optgroup label="Men's">
                                    <% mensCats.forEach(cat=> { %>
                                      <option value="<%=cat._id %>" <%=product.category && product.category._id &&
                                        product.category._id.toString()===cat._id.toString() ? 'selected' : '' %>><%=
                                          cat.categoryName %>
                                      </option>
                                      <% }); %>
                                  </optgroup>
                                  <% } %>
                                    <% if(womensCats.length> 0) { %>
                                      <optgroup label="Women's">
                                        <% womensCats.forEach(cat=> { %>
                                          <option value="<%=cat._id %>" <%=product.category && product.category._id &&
                                            product.category._id.toString()===cat._id.toString() ? 'selected' : '' %>>
                                            <%= cat.categoryName %>
                                          </option>
                                          <% }); %>
                                      </optgroup>
                                      <% } %>
                          </select>
                        </div>
                        <div>
                          <label class="form-label">Stock</label>
                          <input type="number" name="quantity" min="1" value="<%=product.quantity %>" required
                            class="form-control">
                        </div>
                        <div>
                          <label class="form-label">Price</label>
                          <input type="number" name="price" min="1" value="<%=product.price %>" required
                            class="form-control">
                        </div>
                        <div>
                          <label class="form-label">Delivery Charges (Rs)</label>
                          <input type="number" name="deliveryCharges" min="0" step="0.01"
                            value="<%= typeof product.deliveryCharges !== 'undefined' ? product.deliveryCharges : 0 %>"
                            required class="form-control">
                        </div>
                        <div class="form-check mt-2">
                          <% if(product.increaseDeliveryChargesWithQuantity){ %>
                            <input class="form-check-input" checked type="checkbox"
                              name="increaseDeliveryChargesWithQuantity"
                              id="increaseDeliveryChargesWithQuantity-<%= product.id %>">
                            <% } else { %>
                              <input class="form-check-input" type="checkbox" name="increaseDeliveryChargesWithQuantity"
                                id="increaseDeliveryChargesWithQuantity-<%= product.id %>">
                              <% } %>
                                <label class="form-check-label"
                                  for="increaseDeliveryChargesWithQuantity-<%= product.id %>">Increase delivery charges
                                  with quantity</label>
                        </div>
                        <div>
                          <label class="form-label">Discount <span class="text-muted">(in percentage)</span></label>
                          <input type="number" name="discount" min="0" max="100" step="0.01"
                            value="<%=product.discount %>" class="form-control" placeholder="Optional">
                        </div>
                        <div class="mt-2">
                          <% if(product.isWholesaleSet) { %>
                            <input type="hidden" name="isWholesaleSet" value="on">
                            <input type="hidden" name="piecesPerSet" value="<%= product.piecesPerSet || 1 %>">
                          <% } %>
                        </div>
                        <div class="form-check form-switch mt-2">
                          <% if(product.isFeatured){%>
                            <input class="form-check-input" checked type="checkbox" name="isFeatured"
                              id="flexSwitchCheckDefault">
                            <% }else{%>
                              <input class="form-check-input" type="checkbox" name="isFeatured"
                                id="flexSwitchCheckDefault">
                              <% } %>
                                <label class="form-check-label" for="flexSwitchCheckDefault">Is Featured ?</label>
                        </div>
                        <div><label class="form-label">Description</label></div>
                        <div><textarea name="description" rows="5" class="form-control" placeholder="Add description"
                            required><%=product.description %></textarea></div>
                        <div>
                          <label class="form-label mt-2">Manage Existing Images</label>
                          <div class="mb-2" id="existingImagesContainer-<%= product.id %>">
                            <% if(product.productImagePath && product.productImagePath.length > 0) { %>
                              <div class="mb-2" id="deleteAllBtnContainer-<%= product.id %>">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAllExistingImages('<%= product.id %>')">Delete All Images</button>
                              </div>
                              <div class="d-flex flex-wrap gap-2" id="existingImagesList-<%= product.id %>">
                                <% product.productImagePath.forEach((img, i) => { %>
                                  <div class="d-inline-block position-relative m-1 border rounded p-1 existing-image-wrapper-<%= product.id %>" data-img="<%= img %>">
                                    <img src="<%= img.startsWith('http') ? img : '/files/' + img %>" width="70" height="70" class="rounded" style="object-fit:cover;">
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" style="width:20px; height:20px; line-height:1; transform: translate(50%, -50%);" onclick="deleteExistingImage(this, '<%= product.id %>', '<%= img %>')">&times;</button>
                                  </div>
                                <% }) %>
                              </div>
                            <% } else { %>
                              <span class="text-muted small" id="noImagesText-<%= product.id %>">No images available</span>
                            <% } %>
                          </div>
                          <!-- Hidden inputs for deleted images will be appended here -->
                          <div id="deletedImagesInputs-<%= product.id %>"></div>

                          <label class="form-label mt-2">Upload New Images <span class="text-muted">(Optional)</span></label>
                          <input type="file" multiple name="productImages" class="form-control edit-product-images-input" data-product-id="<%= product.id %>" onchange="compressEditImages(event, '<%= product.id %>')" id="editProductImagesInput-<%= product.id %>">
                          <div class="mt-2" id="previewEditProductImages-<%= product.id %>"></div>
                        </div>
                    <div class="modal-footer mt-3">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                      <button type="submit" class="btn btn-dark submit-btn">Save changes</button>
                    </div>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
</div>

<style>
.product-loader-overlay {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(255, 255, 255, 0.95);
  z-index: 999999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.animation-container {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
  color: #333;
  margin-bottom: 20px;
  position: relative;
  width: 300px;
  height: 120px;
}
.box-icon {
  position: absolute;
  left: 20px;
  color: #8b5a2b;
}
.computer-icon {
  position: absolute;
  right: 20px;
  color: #273952;
}
.flying-product {
  position: absolute;
  left: 50px;
  font-size: 2.5rem;
  color: #198754;
  animation: flyToComputer 2s infinite ease-in-out;
}
@keyframes flyToComputer {
  0% { transform: translate(0, 20px) scale(0.5); opacity: 0; }
  20% { transform: translate(0, -40px) scale(1); opacity: 1; }
  80% { transform: translate(140px, -40px) scale(1); opacity: 1; }
  100% { transform: translate(140px, 20px) scale(0.5); opacity: 0; }
}
</style>

<div id="productLoaderOverlay" class="product-loader-overlay" style="display: none;">
  <div class="animation-container">
    <i class="fa-solid fa-box-open box-icon"></i>
    <i class="fa-solid fa-shirt flying-product"></i>
    <i class="fa-solid fa-cloud-arrow-up computer-icon"></i>
  </div>
  <h4 style="font-family: 'Cairo', sans-serif; font-weight: bold; color: #273952; letter-spacing: 2px;">UPLOADING PRODUCT...</h4>
  <p class="text-muted">Please wait while we save your product and images.</p>
</div>


<script>
  const editProductDataTransfers = {};

  function deleteExistingImage(btn, productId, imgName) {
    const container = document.getElementById(`deletedImagesInputs-${productId}`);
    container.innerHTML += `<input type="hidden" name="deletedImages" value="${imgName}">`;
    const wrapper = btn.closest(`.existing-image-wrapper-${productId}`);
    wrapper.remove();
    const remaining = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    if(remaining.length === 0) {
        const btnContainer = document.getElementById(`deleteAllBtnContainer-${productId}`);
        if(btnContainer) btnContainer.style.display = 'none';
    }
  }

  function deleteAllExistingImages(productId) {
    const wrappers = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    wrappers.forEach(wrapper => {
      const imgName = wrapper.getAttribute('data-img');
      const container = document.getElementById(`deletedImagesInputs-${productId}`);
      container.innerHTML += `<input type="hidden" name="deletedImages" value="${imgName}">`;
      wrapper.remove();
    });
    const btnContainer = document.getElementById(`deleteAllBtnContainer-${productId}`);
    if(btnContainer) btnContainer.style.display = 'none';
  }

  async function compressEditImages(event, productId) {
    const input = event.target;
    const form = input.closest('form');
    const btn = form.querySelector('.submit-btn');
    if(btn) {
      btn.disabled = true;
      btn.innerHTML = 'Compressing...';
    }

    if (!editProductDataTransfers[productId]) {
        editProductDataTransfers[productId] = new DataTransfer();
    }
    const dt = editProductDataTransfers[productId];

    let filesToProcess = [];
    try {
      for (let file of input.files) {
        if (file.name.match(/\.zip$/i) || file.type === 'application/zip' || file.type === 'application/x-zip-compressed') {
          const zip = await JSZip.loadAsync(file);
          for (const [filename, zipEntry] of Object.entries(zip.files)) {
            if (!zipEntry.dir && filename.match(/\.(jpg|jpeg|png|webp|gif)$/i)) {
               const blob = await zipEntry.async("blob");
               filesToProcess.push(new File([blob], filename, { type: blob.type }));
            }
          }
        } else if (file.name.match(/\.pdf$/i) || file.type === 'application/pdf') {
          const arrayBuffer = await file.arrayBuffer();
          const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
          for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const viewport = page.getViewport({ scale: 1.5 });
            const canvas = document.createElement("canvas");
            const ctx = canvas.getContext("2d");
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            await page.render({ canvasContext: ctx, viewport: viewport }).promise;
            const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/jpeg", 0.9));
            filesToProcess.push(new File([blob], file.name.replace('.pdf','') + `-page-${i}.jpg`, { type: "image/jpeg" }));
          }
        } else if (file.type.startsWith("image/")) {
          filesToProcess.push(file);
        }
      }
    } catch (e) {
      console.error(e);
      alert("Error processing files: " + e.message);
    }

    if (filesToProcess.length > 60) {
      alert("cant upload images due to limit cross of images");
      input.value = "";
      if(btn) {
        btn.disabled = false;
        btn.innerHTML = 'Save changes';
      }
      return;
    }

    const options = { 
      maxSizeMB: 1.5, 
      maxWidthOrHeight: 1500, // HD resolution
      useWebWorker: true,
      initialQuality: 0.95
    };
    for (let file of filesToProcess) {
      try {
        const compressedFile = await imageCompression(file, options);
        dt.items.add(new File([compressedFile], file.name, { type: file.type }));
      } catch (err) {
        dt.items.add(file);
      }
    }
    input.files = dt.files;
    renderEditProductPreview(productId);
    
    if(btn) {
      btn.disabled = false;
      btn.innerHTML = 'Save changes';
    }
  }

  function renderEditProductPreview(productId) {
    const container = document.getElementById(`previewEditProductImages-${productId}`);
    container.innerHTML = "";
    const dt = editProductDataTransfers[productId];
    if(!dt || dt.files.length === 0) return;

    container.innerHTML = `<div class="mb-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAllNewEditImages('${productId}')">Remove All New Images</button></div>`;
    Array.from(dt.files).forEach((file, index) => {
      let src = URL.createObjectURL(file);
      container.innerHTML += `
        <div class="d-inline-block position-relative m-1 border rounded p-1">
          <img src='${src}' alt='' width='70' height='70' class='rounded' style='object-fit:cover;'>
          <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" style="width:20px; height:20px; line-height:1; transform: translate(50%, -50%);" onclick="deleteNewEditImage('${productId}', ${index})">&times;</button>
        </div>
      `;
    });
  }

  function deleteNewEditImage(productId, index) {
    const dt = new DataTransfer();
    Array.from(editProductDataTransfers[productId].files).forEach((file, i) => {
      if (i !== index) dt.items.add(file);
    });
    editProductDataTransfers[productId] = dt;
    document.getElementById(`editProductImagesInput-${productId}`).files = dt.files;
    renderEditProductPreview(productId);
  }

  function deleteAllNewEditImages(productId) {
    editProductDataTransfers[productId] = new DataTransfer();
    document.getElementById(`editProductImagesInput-${productId}`).files = editProductDataTransfers[productId].files;
    renderEditProductPreview(productId);
  }

  function exportCsv() {
    myTable.export({
      type: "csv",
      skipColumn: [0, 8],
      filename: "product_details",
    });
  }

  async function handleEditSubmit(event, form, productId) {
    event.preventDefault();
    const existingImages = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    const input = document.getElementById(`editProductImagesInput-${productId}`);
    const newImagesCount = input && input.files ? input.files.length : 0;
    
    if (existingImages.length === 0 && newImagesCount === 0) {
        alert("Minimum 1 image is required for a product. Please add an image before saving.");
        return false;
    }

    const btn = form.querySelector('.submit-btn');
    if(btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Saving...';
    }
    
    const overlay = document.getElementById('productLoaderOverlay');
    const loaderText = document.getElementById('loaderText');
    if (overlay) overlay.style.display = 'flex';
    
    try {
        let dt = editProductDataTransfers[productId];
        if (dt && dt.files.length > 0) {
            let files = dt.files;
            for (let i = 0; i < files.length; i++) {
                if(loaderText) loaderText.innerText = `Uploading HD Image ${i + 1} of ${files.length}...`;
                let fd = new FormData();
                fd.append('image', files[i]);
                let res = await fetch('/admin/uploadSingleImage', { method: 'POST', body: fd });
                let data = await res.json();
                if (data.success) {
                    let hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'uploadedImages';
                    hiddenInput.value = data.url;
                    form.appendChild(hiddenInput);
                } else {
                    throw new Error(data.message || "Upload failed");
                }
            }
            // Clear file input
            if(input) input.value = "";
        }
        
        $(`#editProduct-${productId}`).modal('hide');
        if(loaderText) loaderText.innerText = "Processing details...";
        form.submit();
    } catch(e) {
        alert("Upload error: " + e.message);
        if(overlay) overlay.style.display = 'none';
        if(btn) {
            btn.disabled = false;
            btn.innerHTML = 'Save changes';
        }
    }
    return false; 
  }

  // Initialize Select2 for category dropdown in edit modals
  $(document).ready(function () {
    // Initialize Select2 on page load
    $('.category-select').select2({
      placeholder: "Search and select category...",
      allowClear: true,
      theme: "bootstrap-5",
      width: '100%'
    });
  });

  // Re-initialize Select2 when any edit modal is shown
  $(document).on('show.bs.modal', function (e) {
    const modal = $(e.target);
    modal.find('.category-select').each(function () {
      if (!$(this).data('select2')) {
        $(this).select2({
          placeholder: "Search and select category...",
          allowClear: true,
          theme: "bootstrap-5",
          width: '100%',
          dropdownParent: modal
        });
      }
    });
  });

  // Destroy Select2 when modal is hidden to avoid memory leaks
  $(document).on('hidden.bs.modal', function () {
    $(this).find('.category-select').select2('destroy');
  });
</script>