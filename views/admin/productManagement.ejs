<div class="container-fluid px-4">
  <h1 class="mt-4">Product Management</h1>
  <%- include("../partials/errorMessage") %>
    <div class="card mb-4">
      <div class="card-header">
        <i class="fas fa-table me-1"></i>
        Products
        <%- include("_modal_product") %>
        <%- include("_modal_set_product") %>
          <div class=" float-end">
            <button class="btn btn-dark btn-sm" onclick="exportCsv()">Export <i
                class="fa-solid fa-download"></i></button>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addSetProduct"><i class="fa-solid fa-boxes-stacked"></i> Add Sets Product</button>
            <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addProduct">New Product <i
                class="fa-solid fa-circle-plus"></i></button>
          </div>
      </div>
      <div class="card-body">
        <table id="datatablesSimple">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Price</th>
              <th>Discount %</th>
              <th>Offer Price</th>
              <th>Is Featured</th>
              <th>Action</th>
            </tr>
          </thead>
          <tfoot>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Price</th>
              <th>Discount %</th>
              <th>Offer Price</th>
              <th>Is Featured</th>
              <th>Action</th>
            </tr>
          </tfoot>
          <tbody>
            <% allProducts.forEach(product=>{ %>
              <tr id="product-row-<%= product.id %>">
                <td><img
                    src="<%= product.productImagePath && product.productImagePath.length > 0 ? (product.productImagePath[0].startsWith('http') ? product.productImagePath[0] : '/files/' + product.productImagePath[0]) : '/img/no-image.png' %>"
                    alt="<%= product.name %>" width="60" class="img-fluid img-thumbnail" loading="lazy" decoding="async"></td>
                <td class="product-name">
                  <%= product.name %>
                  <% if(product.isWholesaleSet) { %>
                    <br><span class="badge text-white mt-1" style="background-color:#7fad39; font-size:0.7rem; letter-spacing:1px;"><i class="fa-solid fa-boxes-stacked me-1"></i>SET</span>
                  <% } %>
                </td>
                <td class="product-category">
                  <%= product.category ? product.category.categoryName : '-' %>
                </td>
                <td class="product-quantity">
                  <%= product.quantity %>
                </td>
                <td class="product-price">
                  <%= product.price %>
                </td>
                <td class="product-discount">
                  <%= product.discount %>
                </td>
                <td class="product-offerPrice">
                  <%= product.offerPrice %>
                </td>
                <td class="product-isFeatured">
                <% if(product.isFeatured){%>
                  <span class="badge bg-success">Featured</span>
                <%} %>
                </td>
                <td>
                  <div>
                    <button class="btn btn-sm btn-outline-dark" type="button" onclick="openEditModal('<%= product.id %>')"><i class="fa-solid fa-pen-to-square"></i></button>
                    <button class="btn btn-sm btn-outline-warning" type="button" onclick="confirmMarkOutOfStock('<%= product.id %>')" title="Mark Out Of Stock"><i class="fa-solid fa-ban"></i></button>
                    <button class="btn btn-sm btn-outline-danger" type="button" onclick="confirmDelete('<%= product.id %>')"><i class="fa-solid fa-trash-can"></i></button>
                  </div>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
</div>

<div id="dynamicEditModalContainer"></div>

<div class="modal modal-alert" tabindex="-1" role="dialog" id="globalDeleteModal">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content rounded-3 shadow">
      <div class="modal-body p-4 text-center">
        <h5 class="mb-2">Warning! Are you sure?</h5>
        <p class="mb-0">This change can't be undone.</p>
      </div>
      <div class="modal-footer flex-nowrap p-0">
        <form id="globalDeleteForm" method="post" class="w-100 d-flex m-0">
          <button type="submit" class="btn btn-lg btn-link fs-6 text-decoration-none col-6 m-0 rounded-0 border-end text-danger"><strong>Yes</strong></button>
          <button type="button" class="btn btn-lg btn-link fs-6 text-decoration-none col-6 m-0 rounded-0" data-bs-dismiss="modal">No</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
.product-loader-overlay {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(255, 255, 255, 0.95);
  z-index: 999999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.animation-container {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
  color: #333;
  margin-bottom: 20px;
  position: relative;
  width: 300px;
  height: 120px;
}
.box-icon {
  position: absolute;
  left: 20px;
  color: #8b5a2b;
}
.computer-icon {
  position: absolute;
  right: 20px;
  color: #273952;
}
.flying-product {
  position: absolute;
  left: 50px;
  font-size: 2.5rem;
  color: #198754;
  animation: flyToComputer 2s infinite ease-in-out;
}
@keyframes flyToComputer {
  0% { transform: translate(0, 20px) scale(0.5); opacity: 0; }
  20% { transform: translate(0, -40px) scale(1); opacity: 1; }
  80% { transform: translate(140px, -40px) scale(1); opacity: 1; }
  100% { transform: translate(140px, 20px) scale(0.5); opacity: 0; }
}
</style>

<div id="productLoaderOverlay" class="product-loader-overlay" style="display: none;">
  <div class="animation-container">
    <i class="fa-solid fa-box-open box-icon"></i>
    <i class="fa-solid fa-shirt flying-product"></i>
    <i class="fa-solid fa-cloud-arrow-up computer-icon"></i>
  </div>
  <h4 style="font-family: 'Cairo', sans-serif; font-weight: bold; color: #273952; letter-spacing: 2px;">UPLOADING PRODUCT...</h4>
  <p class="text-muted" id="loaderText">Please wait while we save your product and images.</p>
  <div class="progress mt-2" style="width: 300px; height: 8px; display: none;" id="uploadProgressBar">
    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 0%" id="uploadProgressFill"></div>
  </div>
</div>


<script>
  const editProductDataTransfers = {};

  function deleteExistingImage(btn, productId, imgName) {
    const container = document.getElementById(`deletedImagesInputs-${productId}`);
    container.innerHTML += `<input type="hidden" name="deletedImages" value="${imgName}">`;
    const wrapper = btn.closest(`.existing-image-wrapper-${productId}`);
    wrapper.remove();
    const remaining = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    if(remaining.length === 0) {
        const btnContainer = document.getElementById(`deleteAllBtnContainer-${productId}`);
        if(btnContainer) btnContainer.style.display = 'none';
    }
  }

  function deleteAllExistingImages(productId) {
    const wrappers = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    wrappers.forEach(wrapper => {
      const imgName = wrapper.getAttribute('data-img');
      const container = document.getElementById(`deletedImagesInputs-${productId}`);
      container.innerHTML += `<input type="hidden" name="deletedImages" value="${imgName}">`;
      wrapper.remove();
    });
    const btnContainer = document.getElementById(`deleteAllBtnContainer-${productId}`);
    if(btnContainer) btnContainer.style.display = 'none';
  }

  async function compressEditImages(event, productId) {
    const input = event.target;
    const form = input.closest('form');
    const btn = form.querySelector('.submit-btn');
    if(btn) {
      btn.disabled = true;
      btn.innerHTML = 'Compressing...';
    }

    if (!editProductDataTransfers[productId]) {
        editProductDataTransfers[productId] = new DataTransfer();
    }
    const dt = editProductDataTransfers[productId];

    let filesToProcess = [];
    try {
      for (let file of input.files) {
        if (file.name.match(/\.zip$/i) || file.type === 'application/zip' || file.type === 'application/x-zip-compressed') {
          const zip = await JSZip.loadAsync(file);
          for (const [filename, zipEntry] of Object.entries(zip.files)) {
            if (!zipEntry.dir && filename.match(/\.(jpg|jpeg|png|webp|gif)$/i)) {
               const blob = await zipEntry.async("blob");
               filesToProcess.push(new File([blob], filename, { type: blob.type }));
            }
          }
        } else if (file.name.match(/\.pdf$/i) || file.type === 'application/pdf') {
          const arrayBuffer = await file.arrayBuffer();
          const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;
          for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const viewport = page.getViewport({ scale: 1.5 });
            const canvas = document.createElement("canvas");
            const ctx = canvas.getContext("2d");
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            await page.render({ canvasContext: ctx, viewport: viewport }).promise;
            const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/jpeg", 0.9));
            filesToProcess.push(new File([blob], file.name.replace('.pdf','') + `-page-${i}.jpg`, { type: "image/jpeg" }));
          }
        } else if (file.type.startsWith("image/")) {
          filesToProcess.push(file);
        }
      }
    } catch (e) {
      console.error(e);
      alert("Error processing files: " + e.message);
    }

    if (filesToProcess.length > 60) {
      alert("cant upload images due to limit cross of images");
      input.value = "";
      if(btn) {
        btn.disabled = false;
        btn.innerHTML = 'Save changes';
      }
      return;
    }

    const options = { 
      maxSizeMB: 0.7,
      maxWidthOrHeight: 1920,
      useWebWorker: true,
      initialQuality: 0.85
    };
    for (let file of filesToProcess) {
      try {
        const compressedFile = await imageCompression(file, options);
        dt.items.add(new File([compressedFile], file.name, { type: file.type }));
      } catch (err) {
        dt.items.add(file);
      }
    }
    input.files = dt.files;
    renderEditProductPreview(productId);
    
    if(btn) {
      btn.disabled = false;
      btn.innerHTML = 'Save changes';
    }
  }

  function renderEditProductPreview(productId) {
    const container = document.getElementById(`previewEditProductImages-${productId}`);
    container.innerHTML = "";
    const dt = editProductDataTransfers[productId];
    if(!dt || dt.files.length === 0) return;

    container.innerHTML = `<div class="mb-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAllNewEditImages('${productId}')">Remove All New Images</button></div>`;
    Array.from(dt.files).forEach((file, index) => {
      let src = URL.createObjectURL(file);
      container.innerHTML += `
        <div class="d-inline-block position-relative m-1 border rounded p-1">
          <img src='${src}' alt='' width='70' height='70' class='rounded' style='object-fit:cover;'>
          <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-0 rounded-circle" style="width:20px; height:20px; line-height:1; transform: translate(50%, -50%);" onclick="deleteNewEditImage('${productId}', ${index})">&times;</button>
        </div>
      `;
    });
  }

  function deleteNewEditImage(productId, index) {
    const dt = new DataTransfer();
    Array.from(editProductDataTransfers[productId].files).forEach((file, i) => {
      if (i !== index) dt.items.add(file);
    });
    editProductDataTransfers[productId] = dt;
    document.getElementById(`editProductImagesInput-${productId}`).files = dt.files;
    renderEditProductPreview(productId);
  }

  function deleteAllNewEditImages(productId) {
    editProductDataTransfers[productId] = new DataTransfer();
    document.getElementById(`editProductImagesInput-${productId}`).files = editProductDataTransfers[productId].files;
    renderEditProductPreview(productId);
  }

  function exportCsv() {
    myTable.export({
      type: "csv",
      skipColumn: [0, 8],
      filename: "product_details",
    });
  }

  async function handleEditSubmit(event, form, productId) {
    event.preventDefault();
    const existingImages = document.querySelectorAll(`.existing-image-wrapper-${productId}`);
    const input = document.getElementById(`editProductImagesInput-${productId}`);
    const newImagesCount = input && input.files ? input.files.length : 0;
    
    if (existingImages.length === 0 && newImagesCount === 0) {
        alert("Minimum 1 image is required for a product. Please add an image before saving.");
        return false;
    }

    const btn = form.querySelector('.submit-btn');
    if(btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Saving...';
    }
    
    const overlay = document.getElementById('productLoaderOverlay');
    const loaderText = document.getElementById('loaderText');
    const progressBar = document.getElementById('uploadProgressBar');
    const progressFill = document.getElementById('uploadProgressFill');
    if (overlay) overlay.style.display = 'flex';
    if (progressBar) progressBar.style.display = 'block';
    
    try {
        let dt = editProductDataTransfers[productId];
        if (dt && dt.files.length > 0) {
            let files = dt.files;
            for (let i = 0; i < files.length; i++) {
                let pct = Math.round(((i + 1) / files.length) * 100);
                if(loaderText) loaderText.innerText = `Uploading HD Image ${i + 1} of ${files.length}...`;
                if(progressFill) progressFill.style.width = pct + '%';
                
                let fd = new FormData();
                fd.append('image', files[i]);
                let res = await fetch('/admin/uploadSingleImage', { method: 'POST', body: fd });
                let data = await res.json();
                if (data.success) {
                    let hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'uploadedImages';
                    hiddenInput.value = data.url;
                    form.appendChild(hiddenInput);
                } else {
                    throw new Error(data.message || "Upload failed");
                }
            }
        }
        
        // CRITICAL: Remove the file input name so files are NOT sent with form.submit()
        if(input) input.removeAttribute('name');
        
        const modalEl = document.getElementById(`edit-${productId}`);
        if (modalEl) {
            const modalInstance = bootstrap.Modal.getInstance(modalEl);
            if (modalInstance) {
                modalInstance.hide();
            } else {
                $(`#edit-${productId}`).modal('hide');
            }
        }
        if(loaderText) loaderText.innerText = "Saving product details...";
        
        let finalFormData = new FormData(form);
        let submitRes = await fetch(form.action, {
            method: 'POST', // method-override handles ?_method=PUT
            body: finalFormData,
            headers: {
                'Accept': 'application/json'
            }
        });
        
        let result = await submitRes.json();
        if (result.success) {
            // Update row dynamically
            let row = document.getElementById(`product-row-${productId}`);
            if (row) {
                let nameHtml = finalFormData.get('name');
                if (finalFormData.get('isWholesaleSet') === 'on') {
                    nameHtml += '<br><span class="badge text-white mt-1" style="background-color:#7fad39; font-size:0.7rem; letter-spacing:1px;"><i class="fa-solid fa-boxes-stacked me-1"></i>SET</span>';
                }
                row.querySelector('.product-name').innerHTML = nameHtml;
                row.querySelector('.product-quantity').innerText = finalFormData.get('quantity');
                row.querySelector('.product-price').innerText = finalFormData.get('price');
                
                let discount = finalFormData.get('discount') ? parseFloat(finalFormData.get('discount')) : 0;
                let price = parseFloat(finalFormData.get('price'));
                row.querySelector('.product-discount').innerText = discount || '';
                row.querySelector('.product-offerPrice').innerText = discount ? (price - (price/100)*discount).toFixed(2) : price;
                
                if (finalFormData.get('isFeatured') === 'on') {
                    row.querySelector('.product-isFeatured').innerHTML = '<span class="badge bg-success">Featured</span>';
                } else {
                    row.querySelector('.product-isFeatured').innerHTML = '';
                }
            }
            if (overlay) overlay.style.display = 'none';
            if (progressBar) progressBar.style.display = 'none';
            if(btn) {
                btn.disabled = false;
                btn.innerHTML = 'Save changes';
            }
        } else {
            throw new Error(result.message || "Failed to update product");
        }
        
    } catch(e) {
        alert("Error: " + e.message);
        if(overlay) overlay.style.display = 'none';
        if(progressBar) progressBar.style.display = 'none';
        if(btn) {
            btn.disabled = false;
            btn.innerHTML = 'Save changes';
        }
    }
    return false; 
  }

  // Initialize Select2 for category dropdown in edit modals
  $(document).ready(function () {
    // Initialize Select2 on page load
    $('.category-select').select2({
      placeholder: "Search and select category...",
      allowClear: true,
      theme: "bootstrap-5",
      width: '100%'
    });
  });

  // Re-initialize Select2 when any edit modal is shown
  $(document).on('show.bs.modal', function (e) {
    const modal = $(e.target);
    modal.find('.category-select').each(function () {
      if (!$(this).data('select2')) {
        $(this).select2({
          placeholder: "Search and select category...",
          allowClear: true,
          theme: "bootstrap-5",
          width: '100%',
          dropdownParent: modal
        });
      }
    });
  });

  // Destroy Select2 when modal is hidden to avoid memory leaks
  $(document).on('hidden.bs.modal', function () {
    $(this).find('.category-select').each(function() {
      if ($(this).data('select2')) {
        $(this).select2('destroy');
      }
    });
  });

  async function openEditModal(productId) {
    try {
      // Robustly get current page from pagination DOM
      const activePageEl = document.querySelector('.dataTable-pagination .active a');
      if (activePageEl) {
        let pageNum = activePageEl.dataset ? activePageEl.dataset.page : null;
        if (!pageNum) pageNum = activePageEl.innerText.trim();
        sessionStorage.setItem('dt_saved_page', pageNum);
      } else if (typeof myTable !== 'undefined' && myTable.currentPage) {
        sessionStorage.setItem('dt_saved_page', myTable.currentPage);
      }
      
      const overlay = document.getElementById('productLoaderOverlay');
      const loaderText = document.getElementById('loaderText');
      if(overlay) overlay.style.display = 'flex';
      if(loaderText) loaderText.innerText = "Loading product details...";

      const response = await fetch(`/admin/editProductModal/${productId}`);
      if (!response.ok) throw new Error("Failed to load");
      const html = await response.text();
      
      const container = document.getElementById('dynamicEditModalContainer');
      container.innerHTML = html;
      
      if(overlay) overlay.style.display = 'none';

      const modalEl = document.getElementById(`edit-${productId}`);
      const modal = new bootstrap.Modal(modalEl);
      modal.show();

      // Clear the container when hidden to prevent duplicate IDs in DOM
      modalEl.addEventListener('hidden.bs.modal', () => {
        container.innerHTML = '';
        delete editProductDataTransfers[productId];
      });
      
    } catch (e) {
      alert("Error loading product data.");
      const overlay = document.getElementById('productLoaderOverlay');
      if(overlay) overlay.style.display = 'none';
    }
  }

  function confirmDelete(productId) {
    document.getElementById('globalDeleteForm').action = `/admin/deleteProduct/${productId}?_method=DELETE`;
    const modal = new bootstrap.Modal(document.getElementById('globalDeleteModal'));
    modal.show();
  }

  async function confirmMarkOutOfStock(productId) {
    if (confirm("Are you sure you want to mark this product as out of stock? This will set its quantity to 0.")) {
      try {
        const response = await fetch(`/admin/markOutOfStock/${productId}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          }
        });
        const result = await response.json();
        if (result.success) {
          // Dynamically update the row quantity to 0
          let row = document.getElementById(`product-row-${productId}`);
          if (row) {
            row.querySelector('.product-quantity').innerText = '0';
          }
        } else {
          alert("Error: " + result.message);
        }
      } catch (e) {
        alert("Failed to update stock.");
      }
    }
  }
</script>