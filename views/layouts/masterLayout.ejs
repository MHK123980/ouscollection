  <style>
    #preloder {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: #ffffff;
      z-index: 999999;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
    }
    .fabric-loader {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .spool {
      width: 30px;
      height: 50px;
      background: #8b5a2b;
      position: relative;
      border-radius: 4px;
    }
    .spool::before, .spool::after {
      content: '';
      position: absolute;
      width: 50px;
      height: 8px;
      background: #d2a679;
      left: -10px;
      border-radius: 2px;
    }
    .spool::before { top: -4px; }
    .spool::after { bottom: -4px; }
    .thread {
      position: absolute;
      width: 100%;
      height: 36px;
      top: 7px;
      background: repeating-linear-gradient(
        0deg,
        rgb(39, 57, 82),
        rgb(39, 57, 82) 4px,
        rgb(97, 103, 147) 4px,
        rgb(97, 103, 147) 8px
      );
      animation: unwind 0.8s linear infinite;
    }
    @keyframes unwind {
      0% { background-position: 0 0; }
      100% { background-position: 0 8px; }
    }
    .loader-text {
      margin-top: 20px;
      font-family: 'Cairo', sans-serif;
      color: rgb(39, 57, 82);
      font-weight: 700;
      letter-spacing: 3px;
      animation: pulseText 1.5s ease-in-out infinite;
    }
    @keyframes pulseText {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 1; }
    }
  </style>
