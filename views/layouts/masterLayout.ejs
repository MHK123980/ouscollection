  <script src="https://js.pusher.com/8.0/pusher.min.js"></script>
  <script>
    const pusher = new Pusher('f869c5f1434c09e3d729', { cluster: 'ap2' });
    const channel = pusher.subscribe('ecommerce-channel');
    channel.bind('site_updated', async () => {
      try {
        const response = await fetch(window.location.href);
        const html = await response.text();
        const parser = new DOMParser();
        const newDoc = parser.parseFromString(html, 'text/html');
        
        // Safe containers that can be updated without breaking slider plugins
        const safeContainers = [
          '#allProductsContainer',
          '#setsProductsContainer',
          '.featured__filter',
          '#product-grid-container'
        ];
        
        let updated = false;
        safeContainers.forEach(selector => {
          const oldEl = document.querySelector(selector);
          const newEl = newDoc.querySelector(selector);
          if (oldEl && newEl) {
            oldEl.innerHTML = newEl.innerHTML;
            
            // Re-apply background images for new lazy-loaded elements
            const setBgs = oldEl.querySelectorAll('.set-bg');
            setBgs.forEach(el => {
              const bg = el.getAttribute('data-setbg');
              if (bg) el.style.backgroundImage = 'url(' + bg + ')';
            });
            
            updated = true;
          }
        });
        
        // Re-initialize MixItUp if the filter container was updated
        if (updated && document.querySelector('.featured__filter') && typeof mixitup !== 'undefined') {
          // mixitup handles re-instantiation internally if we call it again on the same container
          mixitup('.featured__filter');
        }
        
        if (updated && typeof toastr !== 'undefined') {
          toastr.success('Website content updated live!');
        }
      } catch (err) {
        console.error('Live update failed:', err);
      }
    });
  </script>


  <script>
    const currentLocation = (location.href).toLowerCase()
    const navItem = document.querySelectorAll(".nav-item")
    const length = navItem.length
    for (let i = 0; i < length; i++) {
      if (navItem[i].href === currentLocation) {
        navItem[i].closest("li").className = "active"
      }
    }
  </script>

  <%- script %>
