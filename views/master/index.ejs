<style>
  body {
    background-image: url('/img/homepage-bg.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
  }
  .header {
    background-color: rgba(255, 255, 255, 0.95) !important;
  }
  .footer {
    background-color: rgba(243, 246, 250, 0.95) !important;
  }
</style>
<!-- Hero Section Begin -->
<section class="hero">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="hero__search">
          <div class="hero__search__form autocomplete">
            <form action="/search/1" method="get">
              <div class="hero__search__categories">
                All Categories
                <span class="arrow_carrot-down"></span>
              </div>
              <input type="text" placeholder="What do you need?" required name="name" id="searchKey" onkeyup="sendData(this)">
              <button type="submit" class="site-btn">SEARCH</button>
            </form>
          </div>
        </div>
        <% if(primaryBanner){%>
        <div class="hero__item set-bg primary-banner" data-setbg="<%= primaryBanner.bannerImagePath.startsWith('http') ? primaryBanner.bannerImagePath : '/files/' + primaryBanner.bannerImagePath %>">
          <div class="hero__text">
            <span>OUS Collection</span>
            <h2><%= primaryBanner.title %> <br><%= primaryBanner.caption %></h2>
            <p>Use Coupon ONAM100</p>
            <a href="<%= primaryBanner.url %>" class="primary-btn">SHOP NOW</a>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
<!-- Hero Section End -->



<!-- Featured Section Begin -->
<section class="featured spad">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="section-title">
          <h2>Featured Product</h2>
        </div>
      </div>
    </div>
    <div class="row featured__filter">
      <% const featuredLimit = featuredProducts.slice(0, 7); %>
      <% featuredLimit.forEach((product)=> { %>
      <div class="col-lg-3 col-md-4 col-sm-6 mix <%= product.category ? product.category.categoryName : 'Uncategorized' %>">
        <%- include('../partials/_productCard', { product: product }) %>
      </div>
      <% }) %>
      <div class="col-lg-3 col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">
        <a href="/shop/featured/1" class="w-100 d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background: #f8f9fa; border: 2px dashed #ddd; min-height: 350px; border-radius: 10px; transition: all 0.3s ease;">
          <i class="fa fa-arrow-right fa-3x mb-3" style="color: #7fad39;"></i>
          <h4 style="color: #1c1c1c; font-weight: 700;">Show All</h4>
          <span style="color: #666;">Featured Products</span>
        </a>
      </div>
    </div>
  </div>
</section>
<!-- Featured Section End -->

<!-- All Products Section Begin -->
<section class="featured spad" style="padding-top: 30px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="section-title">
          <h2>All Products</h2>
        </div>
      </div>
    </div>
    <div class="row" id="allProductsContainer">
      <% if(allProducts && allProducts.length > 0) { %>
        <% const allLimit = allProducts.slice(0, 7); %>
        <% allLimit.forEach((product) => { %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
          <%- include('../partials/_productCard', { product: product }) %>
        </div>
        <% }) %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">
          <a href="/shop/1" class="w-100 d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background: #f8f9fa; border: 2px dashed #ddd; min-height: 350px; border-radius: 10px; transition: all 0.3s ease;">
            <i class="fa fa-arrow-right fa-3x mb-3" style="color: #7fad39;"></i>
            <h4 style="color: #1c1c1c; font-weight: 700;">Show All</h4>
            <span style="color: #666;">Products</span>
          </a>
        </div>
      <% } else { %>
        <div class="col-12 text-center">
          <p class="text-muted">No products available yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>
<!-- All Products Section End -->

<!-- Sets Products Section Begin -->
<section class="featured spad" style="padding-top: 30px;">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="section-title">
          <h2>Sets Products</h2>
        </div>
      </div>
    </div>
    <div class="row" id="setsProductsContainer">
      <% if(setProducts && setProducts.length > 0) { %>
        <% const setsLimit = setProducts.slice(0, 7); %>
        <% setsLimit.forEach((product) => { %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
          <%- include('../partials/_productCard', { product: product }) %>
        </div>
        <% }) %>
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4 d-flex align-items-stretch">
          <a href="/shop/sets/1" class="w-100 d-flex flex-column align-items-center justify-content-center text-decoration-none" style="background: #f8f9fa; border: 2px dashed #ddd; min-height: 350px; border-radius: 10px; transition: all 0.3s ease;">
            <i class="fa fa-arrow-right fa-3x mb-3" style="color: #7fad39;"></i>
            <h4 style="color: #1c1c1c; font-weight: 700;">Show All</h4>
            <span style="color: #666;">Sets Products</span>
          </a>
        </div>
      <% } else { %>
        <div class="col-12 text-center">
          <p class="text-muted">No Sets Products available yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>
<!-- Sets Products Section End -->

<% if(secondaryBanner){%>
<!-- Banner Begin -->
<div class="banner">
  <div class="container">
    <div class="row">
      <% secondaryBanner.forEach(banner=>{ %>
      <div class="col-lg-6 col-md-6 col-sm-6">
        <div class="banner__pic">
          <img src="<%= banner.bannerImagePath.startsWith('http') ? banner.bannerImagePath : '/files/' + banner.bannerImagePath %> " alt="">
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
<!-- Banner End -->
<%} %>

<!-- Latest Product Section Begin -->
<section class="latest-product spad" id="latestProducts">
  <div class="container">
    <div class="row">
      <div class="col-lg-4 col-md-6">
        <div class="latest-product__text">
          <h4>Latest Products</h4>
          <div class="latest-product__slider owl-carousel">
            <div class="latest-prdouct__slider__item">
              <% latestProducts.slice(0,3).forEach((product)=> { %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>
            <div class="latest-prdouct__slider__item">
              <% latestProducts.slice(3,6).forEach((product)=> { %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="latest-product__text">
          <h4>Top Rated Products</h4>
          <div class="latest-product__slider owl-carousel">

            <div class="latest-prdouct__slider__item">
              <% topRatedProducts.slice(0,3).forEach((product)=>{ %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>

            <div class="latest-prdouct__slider__item">
              <% topRatedProducts.slice(3,6).forEach((product)=>{ %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>

          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="latest-product__text">
          <h4>Review Products</h4>
          <div class="latest-product__slider owl-carousel">
            <div class="latest-prdouct__slider__item">

              <% topReviewedProducts.slice(0,3).forEach((product)=>{ %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>

            <div class="latest-prdouct__slider__item">

              <% topReviewedProducts.slice(3,6).forEach((product)=>{ %>
              <%- include('../partials/_smallProductCard', { product: product }) %>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Latest Product Section End -->
